# --- IDEs ---
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/shelf/
.idea/dataSources/
# .vscode/ mostly ignored (auto-generated state). We commit launch.json
# so VSCode users get the same run configs as PyCharm users.
.vscode/*
!.vscode/launch.json
*.swp
*.swo
.DS_Store

# --- Testing / coverage ---
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- DAG examples: anything written by sample tasks ---
data/sample/out/
data/sample/checkpoints/

# --- Agent / editor session state (not source) ---
.omo/

.idea/vcs.xml
